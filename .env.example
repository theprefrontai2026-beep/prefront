# Copy to .env and fill in an LLM key. Used by skill-builder (extract-rules)
# and semantic-layer (semantic mapper).
LLM_PROVIDER=groq

GROQ_API_KEY=
NVIDIA_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# CommerceRisk datasource (external, on the host). Override if it's elsewhere.
DATABASE_URL=postgresql://commercerisk:commercerisk@host.docker.internal:5433/commercerisk
