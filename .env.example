# Copy to .env and fill in an LLM key. Used by skill-builder (extract-rules)
# and semantic-layer (semantic mapper).
LLM_PROVIDER=groq

GROQ_API_KEY=
NVIDIA_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Runtime datasource for semantic-mcp-server. Defaults to the bundled SecureBank
# Postgres (in this compose); override to point the engine at another database.
DATABASE_URL=postgresql://securebank:securebank@securebank-db:5432/securebank
